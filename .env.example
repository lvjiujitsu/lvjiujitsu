DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=America/Sao_Paulo
DJANGO_LOG_LEVEL=INFO
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=db.sqlite3
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@lvjiujitsu.local
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=true
DJSTRIPE_ENABLED=false
DJSTRIPE_MIRROR_STRICT=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_API_VERSION=2026-02-25.clover
STRIPE_CHECKOUT_SUCCESS_PATH=/portal/financeiro/minhas-faturas/
STRIPE_CHECKOUT_CANCEL_PATH=/portal/financeiro/minhas-faturas/
STRIPE_CUSTOMER_PORTAL_RETURN_PATH=/portal/financeiro/minhas-faturas/
STRIPE_PAUSE_COLLECTION_BEHAVIOR=mark_uncollectible
